# === Required Tokens ===
GITHUB_TOKEN=ghp_your_github_token_here
CLAUDE_SETUP_TOKEN=your_claude_setup_token_here
# SwarmOps API key - sent as Bearer token (configure API_KEYS on SwarmOps side)
SWARMOPS_API_KEY=your_swarmops_api_key_here

# === GitHub Configuration ===
# Format: owner/repo (can be changed to any repo)
GITHUB_REPO=spheron-core/landing-site
GITHUB_BLOG_LABEL=blog
GITHUB_AGENT_LABEL=agent
GITHUB_BOT_USERNAME=claude-swarmops
GITHUB_REVIEWER_USERNAME=rekpero

# === SwarmOps ===
SWARMOPS_URL=http://67.220.95.148:8420
SWARMOPS_TRIGGER_MENTION=@claude-swarmops work on this

# === Spheron ===
SPHERON_PRICING_API=https://app.spheron.ai/api/gpu-offers
SPHERON_DOCS_URL=https://docs.spheron.ai
SPHERON_BLOG_URL=https://www.spheron.network/blog/

# === Agent Settings ===
# Discovery runs daily at this hour (24h format)
DISCOVERY_CRON_HOUR=9
DISCOVERY_CRON_MINUTE=0
DISCOVERY_TOPIC_COUNT=3
# PR review polling interval in seconds
PR_POLL_INTERVAL_SECONDS=120
# Max review iterations before escalating to human
MAX_REVIEW_ITERATIONS=5

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8500

# === Claude Code ===
CLAUDE_CMD=claude
CLAUDE_MAX_TURNS=30
