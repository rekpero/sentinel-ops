# === Production Environment ===
# Copy this to .env and fill in real values

# Required tokens
GITHUB_TOKEN=
CLAUDE_SETUP_TOKEN=
SWARMOPS_API_KEY=

# GitHub
GITHUB_REPO=spheron-core/landing-site
GITHUB_BLOG_LABEL=blog
GITHUB_AGENT_LABEL=agent
GITHUB_BOT_USERNAME=claude-swarmops
GITHUB_REVIEWER_USERNAME=rekpero

# SwarmOps
SWARMOPS_URL=http://67.220.95.148:8420
SWARMOPS_TRIGGER_MENTION=@claude-swarmops work on this

# Spheron
SPHERON_PRICING_API=https://app.spheron.ai/api/gpu-offers
SPHERON_DOCS_URL=https://docs.spheron.ai
SPHERON_BLOG_URL=https://www.spheron.network/blog/

# Agent settings (production defaults)
DISCOVERY_CRON_HOUR=9
DISCOVERY_CRON_MINUTE=0
DISCOVERY_TOPIC_COUNT=3
PR_POLL_INTERVAL_SECONDS=120
MAX_REVIEW_ITERATIONS=5

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8500

# Database (Docker volume handles persistence)
DATA_DIR=/app/data

# Claude Code
CLAUDE_CMD=claude
CLAUDE_MAX_TURNS=30
